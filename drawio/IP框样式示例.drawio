  <diagram name="IP框样式示例" id="ip-box-style-demo">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="600" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题说明 -->
        <mxCell id="title" value="IP框样式示例 - BPC风格" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- 说明文字 -->
        <mxCell id="desc1" value="设计方案1：紧凑型5框布局" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- ====== 示例1：紧凑型5框布局 ====== -->
        <mxCell id="demo1-title" value="方案1：极小间距，整体感强" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="180" height="20" as="geometry" />
        </mxCell>

        <!-- IP框（顶部） -->
        <mxCell id="demo1-ip" value="10.164.3.19" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- 第二排：交易量（左）+ 成功率（右） -->
        <mxCell id="demo1-txn" value="&lt;font style=&quot;font-size:24px;font-weight:bold&quot;&gt;1250&lt;/font&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;笔&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="demo1-succ" value="&lt;font style=&quot;font-size:24px;font-weight:bold&quot;&gt;99.50&lt;/font&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;%&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="190" y="160" width="90" height="50" as="geometry" />
        </mxCell>

        <!-- 第三排：响应时间（左）+ 响应率（右） -->
        <mxCell id="demo1-rt" value="&lt;font style=&quot;font-size:24px;font-weight:bold&quot;&gt;120&lt;/font&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;ms&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="100" y="210" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="demo1-resp" value="&lt;font style=&quot;font-size:24px;font-weight:bold&quot;&gt;98.50&lt;/font&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;%&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;verticalAlign=middle" vertex="1" parent="1">
