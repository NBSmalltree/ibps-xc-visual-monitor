        </mxCell>

        <!-- 江北应用处理层 → 江北人行网关层（TCP 12222 + 星云路由） -->
        <mxCell id="conn-3-4-jb" value="&lt;b&gt;TCP 12222 + 星云路由&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff" edge="1" source="layer3-jb-bg" target="layer4-jb-bg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== 任务8.4：第四层 → 第五层 连线（人行网关层 → 前置机层） ====== -->

        <!-- 鄞州人行网关层 → 鄞州前置机层（TCP 1424） -->
        <mxCell id="conn-4-5-yz" value="&lt;b&gt;TCP 1424&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff" edge="1" source="layer4-yz-bg" target="layer5-yz-bg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 江北人行网关层 → 江北前置机层（TCP 1424） -->
        <mxCell id="conn-4-5-jb" value="&lt;b&gt;TCP 1424&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff" edge="1" source="layer4-jb-bg" target="layer5-jb-bg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== 任务8.5：第五层 → 第六层 连线（折线，垂直连接） ====== -->

        <!-- 鄞州前置机层 → 人行前置机（IBM MQ 折线） -->
        <mxCell id="conn-5-6-yz" value="&lt;b&gt;IBM MQ&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle" edge="1" source="layer5-yz-bg" target="layer6-bg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 江北前置机层 → 人行前置机（IBM MQ 折线） -->
        <mxCell id="conn-5-6-jb" value="&lt;b&gt;IBM MQ&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle" edge="1" source="layer5-jb-bg" target="layer6-bg" parent="1">
