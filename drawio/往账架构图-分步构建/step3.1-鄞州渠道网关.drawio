        <!-- ====== 任务8.1：第一层 → 第二层 连线（流量入口 → 渠道网关，折线） ====== -->

        <!-- 行内前端渠道 → 鄞州渠道网关区（ESB/星云路由 折线） -->
        <mxCell id="conn-1-2-yz" value="&lt;b&gt;ESB/星云路由&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;dashed=1;dashPattern=8 8;fontSize=10;fontColor=#82b366;labelBackgroundColor=#ffffff;edgeStyle=orthogonalEdgeStyle;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" source="frontend" target="layer2-yz-bg" parent="1">
