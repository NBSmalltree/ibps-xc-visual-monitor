        <mxCell id="conn-2-3-jb-old" value="&lt;b&gt;TCP 12010&lt;/b&gt;" style="endArrow=classic;html=1;strokeColor=#cc0000;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.203;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#cc0000;labelBackgroundColor=#ffffff;edgeStyle=orthogonalEdgeStyle" edge="1" source="layer2-jb-bg" target="layer3-jb-bg" parent="1">
